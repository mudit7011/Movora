{
  "name": "streamingsite",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "backend"
  ],
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev:backend": "npm run dev --workspace=backend",
    "test:backend": "npm run test --workspace=backend",
    "build:backend": "npm run build --workspace=backend",
    "build": "npm run build --workspace=packages/shared && npm run build --workspace=backend",
    "start": "node backend/dist/server.js"
  },
  "dependencies": {
    "framer-motion": "^12.39.0",
    "next": "^16.2.6",
    "react": "^19.2.6",
    "tailwindcss": "^4.3.0"
  }
}
